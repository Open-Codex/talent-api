generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Seniority {
  JUNIOR
  MID
  SENIOR
  STAFF
  LEAD
  PRINCIPAL
}

enum SkillCategory {
  LANGUAGE
  FRAMEWORK
  TOOL
  DATABASE
  CLOUD
}

enum AvatarStyle {
  GEOMETRIC
  ABSTRACT
}

enum DeveloperStatus {
  AVAILABLE
  BUSY
  UNAVAILABLE
}

enum UserRole {
	USER
	ADMIN
}

model Developer {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String

  name            String
  username        String   @unique
  seniority       Seniority
  role            String
  systemRole			UserRole @default(USER)

  bio             String?  @db.VarChar(500)
  readme          String?  @db.Text

  location        String?
  experienceYears Int

  avatarStyle     AvatarStyle
  avatarSeed      String

  status          DeveloperStatus
  remoteOk        Boolean  @default(true)

  githubUrl       String?
  linkedinUrl     String?
  twitterUrl      String?
  portfolioUrl    String?

  featured        Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  projects        Project[]

  skills          DeveloperSkill[]

  @@index([location])
  @@index([seniority])
  @@index([status])
  @@index([createdAt])
}

model Skill {
  id        String        @id @default(cuid())
  name      String        @unique
  category  SkillCategory

  Developer DeveloperSkill[]

  @@index([name])
}

model DeveloperSkill {
  developerId String
  skillId     String

  developer   Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)
  skill       Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([developerId, skillId])
}

model Project {
  id             String    @id @default(cuid())
  developerId    String

  title          String
  description    String

  repoUrl        String?
  productionUrl  String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  developer      Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)
}
